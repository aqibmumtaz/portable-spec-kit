#!/bin/bash
# =============================================================
# PSK pre-commit hook template
# Installed by psk-install-hooks.sh to .git/hooks/pre-commit
#
# Blocks commits if psk-sync-check.sh --quick reports issues.
# KIT-GAP-0075 (v0.6.83): pre-commit runs the FAST --quick gate (sub-second) so
# commits stay fast and agents never reach for --no-verify. The deep --full gate
# moves to the pre-push hook (catches issues before they reach the remote) and
# still runs at prep-release + reflex gates + CI.
#
# Emergency bypass:
#   PSK_SYNC_CHECK_DISABLED=1 git commit -m "..."
#
# Full bypass (not recommended):
#   git commit --no-verify
# =============================================================

if [ "${PSK_SYNC_CHECK_DISABLED:-0}" = "1" ]; then
  exit 0
fi

SCRIPT="$(git rev-parse --show-toplevel)/agent/scripts/psk-sync-check.sh"

# If script missing, don't block (may be a fresh clone without full install)
if [ ! -x "$SCRIPT" ]; then
  exit 0
fi

bash "$SCRIPT" --quick
exit $?
