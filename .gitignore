.DS_Store
.env
.env.*
node_modules/
__pycache__/
*.pyc
.next/
cache/
logs/
*.log

# Playwright / test runner output
test-results/
playwright-report/

# Jira sync transient files (never commit)
agent/.jira-sync.lock
agent/.agent-context.lock
agent/SYNC_RESULT.json

# Reflex ephemeral artifacts — per v0.6.2 design, ALL per-pass outputs are
# now committed (findings.yaml, signoff.md, verdict.md, investigation-log.md,
# coverage.md, pass-plan.md, project-understanding.md, qa-summary.md,
# qa-usage.yaml, test-plan.md, dev-trace.md, deferred-decisions.md,
# regression-diff.md, gates-result.md, .cycle-meta). Retention policy bounds
# disk growth (last 10 pass dirs on disk per reflex/config.yml history_retention).
# Only the sandbox worktree stays gitignored (ephemeral QA scratch).
reflex/sandbox/

# Playground: self-contained demo projects with their own git repos
psk-playground/

# Session stack — in-conversation branching trace (per skills/session-trace.md)
.session-stack.md
.session-archive/

# Reflex loop orchestrator runtime state (per reflex/lib/loop.sh)
agent/.release-state/loop-state.yml
agent/.release-state/loop-state.aborted-*.yml
agent/.release-state/kit-loop-state.yml
agent/.release-state/kit-loop-state.aborted-*.yml
agent/.release-state/adl-drafts.md

# Prep-release + validate runtime artifacts (ephemeral, should not be committed)
agent/.bypass-log
agent/.release-state/.validate-stamp
agent/.release-state/.validation-passed.*
agent/.release-state/critic-task.md
agent/.release-state/critic-result.md
agent/.release-state/dev-task.md
agent/.release-state/.dev-invoke-stamp
agent/.release-state/state
agent/.release-state/qa-task.md
agent/.release-state/qa-synthesis-task.md
agent/.release-state/qa-result.md
agent/.release-state/.qa-invoke-stamp
agent/.release-state/dev-result.md
agent/.release-state/critic-iterations
agent/.release-state/.validate-stamp
agent/.release-state/reflex-auto-submit-consent
agent/.release-state/rft-cache.txt
agent/.release-state/last-prep-release
agent/.release-state/test-ref-cache.txt
agent/.release-state/test-ref-cache.key
agent/.release-state/reflex.lock
agent/.release-state/release.lock
agent/.release-state/.tests-preverified
agent/.release-state/.tests-stamps/
tests/.psk-optimize-counts.cache

# Per-user profiles (created on first session, not shared across contributors)
.portable-spec-kit/user-profile/
reflex/history/.active-cycle

# HF3 (v0.6.60) — retry-queue.yml itself IS committed (durable across sessions);
# only the ephemeral lock directory is excluded.
agent/.workflow-state/.retry-queue.lock/
# QA-D30-RETRY-QUEUE-STALE-01 — the eviction archive is a transient per-machine
# tombstone log (age-out of stale entries), not durable shared state — excluded.
agent/.workflow-state/.retry-queue-archive.yml
# KIT-GAP-0125 — the release/dispatch lock is written to .workflow-state/release.lock
# (NOT .release-state/release.lock, line 66). The transient lock must not block reflex's
# scoped clean-tree precondition.
agent/.workflow-state/release.lock
# QA-D17-PHASE0-*-WALL-CLOCK-01 — Phase-0 helper warm caches (check-rft-integrity +
# doc-code-diff) are mtime-keyed, per-machine, transient — recomputed on any input
# change. Not durable shared state — excluded.
agent/.workflow-state/phase0-cache/
# G28 — legacy/superseded workflow-state archives (watchdog + psk-dispatch cleanup artifacts)
agent/.workflow-state/*.superseded

reflex/lib/_psk028_test_fixture.sh
